# Set this to your deployed backend URL in Vercel dashboard:
#   Project Settings → Environment Variables → VITE_API_URL
#
# Local dev:
#   VITE_API_URL=http://localhost:8000
#
# Deployed backend (Railway / Render / ngrok):
#   VITE_API_URL=https://your-backend.railway.app
#
# The WebSocket URL is derived automatically:
#   http://... → ws://...
#   https://... → wss://...

VITE_API_URL=http://localhost:8000
